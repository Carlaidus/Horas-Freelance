# Copia este fichero como .env para desarrollo local

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# Activar login de usuarios (en Railway: true)
REQUIRE_AUTH=false

# Secreto para las sesiones — cambia esto por algo aleatorio en producción
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Ruta de la base de datos (en Railway usar un volumen: /data/tracker.db)
DB_PATH=./database/tracker.db
